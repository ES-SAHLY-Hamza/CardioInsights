# 3 eme partie : Fuctions graphiques.
help("pie")
# 3 eme partie : Fuctions graphiques.
help("pie")
# Chargez le jeu de données iris
data(iris)
# Pour chaque espèce de fleurs, indiquez le nombre de lignes
table_esp <- table(iris$Species)
print(table_esp)
# Représentation en camembert (pie chart)
pie(table_esp)
# Représentation en bâtons (barplot)
barplot(table_esp)
# Boxplot pour les 4 variables numériques du jeu de données iris
boxplot(iris[, 1:4])
# Boxplot avec titre et sans valeurs extrêmes
boxplot(iris[, 1:4], main="Boxplot des variables numériques",
outline=FALSE)
# Représentation du pie chart et du boxplot sur la même fenêtre graphique
par(mfrow=c(1,2))  # 1 ligne, 2 colonnes
pie(table_esp)
boxplot(iris[, 1:4], main="Boxplot des variables numériques", outline=FALSE)
# Export du graphique en PDF
pdf("graphique.pdf")
par(mfrow=c(1,2))
pie(table_esp)
boxplot(iris[, 1:4], main="Boxplot des variables numériques", outline=FALSE)
dev.off()
# Scatter plot avec longueur des pétales en abscisse et largeur en ordonnées
plot(iris$Petal.Length, iris$Petal.Width,
xlab="Longueur des pétales", ylab="Largeur des pétales",
main="Scatter Plot: Longueur vs. Largeur des pétales")
