modele$deviance
khi=modele$null.deviance-modele$deviance# khi mean D equivalent on F ANOVA
khi
qchisq(0.95,39)
# une autre méthode :
# Création du modèle incluant toutes les variables explicatives, y compris les variables catégorielles
modele <- glm(condition ~ ., data = heart_data, family = "binomial")
# Test de l'effet global des variables catégorielles en utilisant l'ANOVA
anova_modele <- anova(modele, test = "Chisq")
print(anova_modele)
if (anova_modele$`Pr(>Chi)`[1] < 0.05) {
cat("Il existe un effet significatif des variables catégorielles sur la présence de maladie cardiaque.\n")
} else {
cat("Il n'existe pas d'effet significatif des variables catégorielles sur la présence de maladie cardiaque.\n")
}
