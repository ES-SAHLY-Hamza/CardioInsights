# Fonction pour analyser une adresse e-mail et extraire les informations
parseMail <- function(email) {
# Diviser l'adresse e-mail en trois parties en utilisant le point et l'arobase comme délimiteurs
parts <- unlist(strsplit(email, "[.@]"))
# Extraire le prénom, le nom et l'adresse e-mail
prenom <- parts[1]
nom <- parts[2]
adresse_email <- email
# Créer un data.frame avec les informations extraites
info_etudiant <- data.frame(Prenom = prenom, Nom = nom, Adresse_Email = adresse_email)
return(info_etudiant)
}
# Exemple d'utilisation de la fonction avec une adresse e-mail
email_etudiant <- "prenom.nom@etudiant.esisa.ma"
resultat <- parseMail(email_etudiant)
# Affichage du data.frame résultant
print(resultat)
